<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="6dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="15dp"
        android:paddingEnd="8dp"
        android:paddingTop="15dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sidenote"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:letterSpacing="-0.05"
            android:fontFamily="sans-serif" />

        <!-- Delete: only shown for existing notes -->
        <ImageView
            android:id="@+id/btn_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete"
            android:padding="6dp"
            android:contentDescription="Delete note"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Note card: fills available space -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="5dp"
        android:orientation="vertical"
        android:background="@drawable/bg_note_card"
        android:padding="15dp">

        <EditText
            android:id="@+id/edit_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:hint="Title"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:letterSpacing="-0.05"
            android:fontFamily="sans-serif"
            android:background="@null"
            android:maxLines="1"
            android:inputType="textCapSentences" />

        <EditText
            android:id="@+id/edit_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:hint="Start writing..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:letterSpacing="-0.05"
            android:fontFamily="sans-serif"
            android:background="@null"
            android:gravity="top|start"
            android:inputType="textCapSentences|textMultiLine"
            android:overScrollMode="never" />

    </LinearLayout>

    <!-- "My Sidenotes" back pill button -->
    <LinearLayout
        android:id="@+id/btn_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_blue_pill"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="17dp"
        android:paddingBottom="17dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="5dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:letterSpacing="-0.03"
            android:text="My Sidenotes"
            android:textColor="@color/white"
            android:textSize="18sp" />

    </LinearLayout>

</LinearLayout>
