<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="6dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="My Sidenotes"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:letterSpacing="-0.05"
        android:fontFamily="sans-serif"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:paddingTop="15dp"
        android:paddingBottom="6dp" />

    <!-- List area: RecyclerView scrolls behind the floating button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/notes_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:overScrollMode="never" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="No notes yet"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- New Sidenote button floats over the list -->
        <LinearLayout
            android:id="@+id/btn_new_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_blue_pill"
            android:paddingTop="17dp"
            android:paddingBottom="17dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Sidenote"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:letterSpacing="-0.03"
                android:fontFamily="sans-serif"
                android:layout_marginEnd="5dp" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_forward"
                android:contentDescription="@null" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
